#!/usr/bin/env bash
# Restore claude panes from the hub window back to their original windows.

set -uo pipefail

SESSION=$(tmux display-message -p '#S')
STATE_FILE="${TMPDIR:-/tmp}/tmux-claude-collect-${SESSION}.txt"

# Always clean up hub and state file, even if restore fails partway through
cleanup() {
  rm -f "$STATE_FILE"
  tmux kill-window -t "${SESSION}:0" 2>/dev/null || true
}
trap cleanup EXIT

if [[ ! -f "$STATE_FILE" ]]; then
  tmux display-message "No saved state found for session '$SESSION'"
  exit 1
fi

RESTORED=0
ORIGIN_WIN=""

# First pass: restore panes and kill placeholders
while read -r type pane_id win_idx win_name pane_idx; do
  if [[ "$type" == "ORIGIN" ]]; then
    ORIGIN_WIN="$pane_id"  # field reuse: ORIGIN <win_idx> <pane_id>
    continue
  fi
  if [[ "$type" == "CLAUDE" ]]; then
    # Clear the label we set during collect
    tmux select-pane -t "$pane_id" -T "" 2>/dev/null || true

    if tmux list-windows -t "$SESSION" -F '#{window_index}' | grep -qx "$win_idx"; then
      # If claude was the first pane, join before the current first pane so order is preserved
      if [[ -n "${pane_idx:-}" && "$pane_idx" -le 1 ]]; then
        first=$(tmux list-panes -t "${SESSION}:${win_idx}" -F '#{pane_id}' | head -1)
        tmux join-pane -b -s "$pane_id" -t "$first"
      else
        tmux join-pane -s "$pane_id" -t "${SESSION}:${win_idx}"
      fi
    else
      # Original window gone — open a new one rather than losing the pane
      tmux new-window -t "${SESSION}" -n "${win_name}"
      NEW_WIN=$(tmux display-message -p '#{window_index}')
      tmux join-pane -s "$pane_id" -t "${SESSION}:${NEW_WIN}"
    fi
    ((RESTORED++)) || true
  elif [[ "$type" == "PLACEHOLDER" ]]; then
    tmux kill-pane -t "$pane_id" 2>/dev/null || true
  fi
done < "$STATE_FILE"

# Second pass: restore saved layouts
while read -r type rest; do
  [[ "$type" == "LAYOUT" ]] || continue
  win_idx=${rest%% *}
  layout=${rest#* }
  tmux select-layout -t "${SESSION}:${win_idx}" "$layout" 2>/dev/null || true
done < "$STATE_FILE"

# Return to the window we were in before collecting
if [[ -n "$ORIGIN_WIN" ]]; then
  tmux select-window -t "${SESSION}:${ORIGIN_WIN}" 2>/dev/null || true
fi

tmux display-message "Restored $RESTORED claude pane(s)"
